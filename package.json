{
  "name": "@tabygen/ui",
  "version": "0.1.0",
  "description": "Tabygen global design system — brand tokens, Tailwind preset, and CSS variables for Shadcn/ui",
  "type": "module",
  "exports": {
    "./tailwind-preset": "./tokens/generated/tailwind-preset.js",
    "./variables.css": "./tokens/generated/variables.css",
